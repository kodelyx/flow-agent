# ─────────────────────────────────────────────────────────────
#  Flow Agent — all settings live here.
#  No secrets in this file; safe to commit. Edit and restart
#  the backend to apply changes.
# ─────────────────────────────────────────────────────────────

# ─── User knobs (the ones you actually change) ───
# Google Flow project ID (from your labs.google workspace)
DEFAULT_PROJECT=0143adf4-5864-4cb4-abb5-fe4254ad0dc7

# Image model: lite (HARBOR_SEAL) / standard (NARWHAL) / pro (GEM_PIX_2)
IMAGE_MODEL=NARWHAL

# API key clients must send to call this server (empty = no auth)
SERVER_API_KEY=

# ─── Rate limiting (avoid Google's UNUSUAL_ACTIVITY throttle) ───
# Max generation requests in flight at once.
MAX_CONCURRENT_REQUESTS=5
# Minimum seconds between consecutive generation requests.
REQUEST_MIN_INTERVAL=3

# ─── Ports ───
# WebSocket port the Chrome extension connects to
WS_PORT=9227
# HTTP callback port the extension POSTs responses to
HTTP_PORT=8100
# OpenAI-compatible API server
OPENAI_API_HOST=127.0.0.1
OPENAI_API_PORT=8001

# ─── Polling & timeouts ───
# Seconds between polling Google Flow for generation status
POLL_INTERVAL=10
# Max seconds to wait for a video generation before timing out
POLL_TIMEOUT=420
# Max seconds for a single extension roundtrip (a generation submit can
# legitimately run past a minute, so keep this above 90)
API_REQUEST_TIMEOUT=180

# ─── Google Flow backend (do not change unless Google moves it) ───
API_BASE=https://aisandbox-pa.googleapis.com

# ─── Extension bridge (fingerprint-browser friendly) ───
# auto = HTTP hello/poll first, WebSocket fallback; http | ws force one mode
EXT_TRANSPORT=auto
# HTTP session considered online if hello/poll seen within this many seconds
EXT_SESSION_TTL_SEC=20
# Suggested poll interval returned to the extension (ms)
EXT_POLL_INTERVAL_MS=1000
# Keep legacy /ws endpoint available
ENABLE_EXTENSION_WS=1

